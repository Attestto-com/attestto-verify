{
  "name": "@attestto/verify",
  "version": "0.1.0",
  "description": "Web Components for document verification and signing — verify.attestto.com",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/attestto-verify.js",
  "module": "dist/attestto-verify.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/attestto-verify.js",
      "types": "./dist/index.d.ts"
    },
    "./verify": {
      "import": "./dist/components/attestto-verify.js"
    },
    "./sign": {
      "import": "./dist/components/attestto-sign.js"
    },
    "./plugins/did-verifier": {
      "import": "./dist/plugins/did-verifier.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@attestto/id-wallet-adapter": "^0.3.0",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/attestto/verify"
  },
  "homepage": "https://verify.attestto.com",
  "author": "Eduardo Chongkan <eduardo@attestto.com>",
  "contributors": [
    "Guillermo Chavarria <guillermocc@attestto.com>"
  ]
}
